# =========================================================
# PRODUCTION (saat ini domain deploy kamu)
# Saat pindah ke Vercel, ganti 3 URL di bawah ke domain Vercel kamu.
# =========================================================
# NEXT_PUBLIC_APP_URL=dummy

# Spotify OAuth
# SPOTIFY_CLIENT_ID=dummy
# SPOTIFY_CLIENT_SECRET=dummy
# SPOTIFY_REDIRECT_URI=dummy/api/spotify/callback

# YouTube OAuth (Google Cloud)
# YOUTUBE_CLIENT_ID=dummy
# YOUTUBE_CLIENT_SECRET=dummy
# YOUTUBE_REDIRECT_URI=dummy/api/youtube/callback

# Gemini NLG (Google AI Studio)
# GEMINI_API_KEY=dummy
# GEMINI_MODEL=dummy

# =========================================================
# LOCAL DEVELOPMENT (opsional override di .env.local)
# =========================================================
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback
# YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/callback
